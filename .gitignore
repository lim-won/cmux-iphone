**/node_modules/

# Build outputs
**/build/
**/DerivedData/

# Xcode user state
**/xcuserdata/
**/*.xcuserstate

# macOS filesystem noise
.DS_Store
**/.DS_Store

# Editor temp files
*.swp
*.swo
*~

# Secrets — generated at runtime outside the repo; never commit (defense in depth)
**/session-token
**/hook-secret
**/cmux-password
*.plist.local

# Local Claude Code overrides (user-specific; the shared SKILL.md is still tracked)
**/.claude/settings.local.json

# Env files (keep .env.example committable)
.env
.env.*
!.env.example
!.env.sample

# Apple signing / provisioning material — never commit
*.p12
*.cer
*.mobileprovision
*.xcconfig.local

# Logs
*.log
